/**
 * Extract properties from Python agent action format
 * Handles both {props: {...}} and direct property formats
 */
export function extractActionProps(action: any): any {
  if (action.props) {
    return action.props;
  }
  
  // Extract properties, excluding action metadata
  const { action: actionType, index, id, ...props } = action;
  return props;
}

/**
 * Enhanced component update functions that handle Python agent action format
 */

